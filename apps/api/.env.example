# Copy to .env and fill from your secrets manager. NEVER commit real secrets.
# Local dev: SQLite. Production: Supabase Postgres — use the *connection pooling*
# URI (Supabase → Project Settings → Database → Connection pooling, mode=Transaction):
#   DATABASE_URL=postgresql+psycopg2://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DATABASE_URL=sqlite:///./csc_dev.db
# 32+ byte secret for field-level encryption of sensitive data (birth/chat/KYC).
FIELD_ENCRYPTION_KEY=change-me-to-a-strong-32byte-secret
JWT_SECRET=change-me
DATA_REGION=ap-south-1

# Upstream astrology engine (existing astral-knowledge API)
ASTRO_API_BASE_URL=http://localhost:8000
ASTRO_API_KEY=

# Google Sign-In — OAuth client IDs (from Google Cloud Console). The backend
# verifies that an incoming Google token's audience matches one of these.
# Set the ones you use (web is needed for Expo Go / web).
GOOGLE_WEB_CLIENT_ID=
GOOGLE_IOS_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# Location: server-side places/geocoding key (kept off the client)
GEOCODE_PROVIDER=google
GEOCODE_API_KEY=

# Supabase (Project Settings → API Keys). New key model: PUBLISHABLE = public-safe
# (replaces anon), SECRET = server-only (replaces service_role). DATABASE_URL above
# carries the Postgres link.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_STORAGE_BUCKET=photos
